{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Démarrer le serveur Node.js",
            "program": "${workspaceFolder}/server.js",
            "console": "integratedTerminal"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Ouvrir Chrome sur localhost",
            "url": "http://localhost:5500",
            "webRoot": "${workspaceFolder}"
        }
    ],
    "compounds": [
        {
            "name": "🚀 Lancer le projet complet",
            "configurations": ["Démarrer le serveur Node.js", "Ouvrir Chrome sur localhost"]
        }
    ]
}
